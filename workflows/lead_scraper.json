          { "node": "Is High-Quality Lead?", "type": "main", "index": 0 },
          { "node": "Generate Run Summary", "type": "main", "index": 0 }
        ]
      ]
    },
    "Is High-Quality Lead?": {
      "main": [
        [
          { "node": "Slack Alert (Hot Lead)", "type": "main", "index": 0 },
          { "node": "Email Sales Team", "type": "main", "index": 0 }
        ],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
