  "_comment": "Copy this file to credentials.json and fill in your actual API keys. NEVER commit credentials.json to version control.",

  "google_sheets": {
    "type": "OAuth2",
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "client_secret": "YOUR_GOOGLE_CLIENT_SECRET",
