    "channels": {
      "new_leads": "#leads-new",
      "high_priority": "#sales-high-priority",
      "scored_leads": "#leads-scored",
      "alerts": "#leads-alerts"
    },
    "setup_guide": "https://docs.n8n.io/integrations/builtin/credentials/slack/"
  },

  "anthropic_claude": {
    "type": "API Key",
